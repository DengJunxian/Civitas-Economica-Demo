# Optional cloud model keys. Leave empty for offline demo mode.
DEEPSEEK_API_KEY=
ZHIPU_API_KEY=

# Optional inference profile: lite | standard | enterprise
CIVITAS_INFERENCE_MODE=lite

# Optional local model path for standard mode
CIVITAS_LOCAL_MODEL_PATH=

# Optional vLLM model name for enterprise mode
CIVITAS_VLLM_MODEL=deepseek-ai/DeepSeek-R1-Distill-Qwen-7B
